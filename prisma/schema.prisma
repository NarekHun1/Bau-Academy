generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TrainingUser {
  id         Int      @id @default(autoincrement())
  telegramId String   @unique
  username   String?
  firstName  String?
  lastName   String?
  hasAccess  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  fullName   String?

  awaitingCertificateName Boolean @default(false)
  certificateAttemptId    Int?

  codes               AccessCode[]
  requests            AccessRequest[]
  LessonAccessRequest LessonAccessRequest[]
  lessonAccess        UserLessonAccess[]
  UserChapterProgress UserChapterProgress[]
  QuizAttempt         QuizAttempt[]
  LessonReview        LessonReview[]
}

model AccessRequest {
  id        Int           @id @default(autoincrement())
  userId    Int
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  decidedAt DateTime?
  user      TrainingUser  @relation(fields: [userId], references: [id])
}

model AccessCode {
  id        Int          @id @default(autoincrement())
  code      String       @unique
  userId    Int
  isUsed    Boolean      @default(false)
  usedAt    DateTime?
  createdAt DateTime     @default(now())
  expiresAt DateTime?
  user      TrainingUser @relation(fields: [userId], references: [id])
}

model Lesson {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  createdAt DateTime @default(now())

  accesses            UserLessonAccess[]
  LessonAccessRequest LessonAccessRequest[]
  chapters            LessonChapter[]
  UserChapterProgress UserChapterProgress[]
  LessonQuiz          LessonQuiz[]
  LessonReview        LessonReview[]
}

model LessonChapter {
  id        Int      @id @default(autoincrement())
  lessonId  Int
  order     Int
  slug      String
  title     String
  createdAt DateTime @default(now())

  lesson              Lesson                @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  items               LessonItem[]
  UserChapterProgress UserChapterProgress[]
  LessonQuiz          LessonQuiz[]

  @@unique([lessonId, slug], name: "lessonId_slug_chapter")
  @@unique([lessonId, order], name: "lessonId_order_chapter")
  @@index([lessonId, order])
}

model LessonItem {
  id        Int @id @default(autoincrement())
  chapterId Int

  type      LessonItemType
  title     String?
  url       String?
  fileId    String?
  text      String?
  order     Int            @default(0)
  createdAt DateTime       @default(now())

  chapter LessonChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, order], name: "chapterId_order")
  @@index([chapterId, order])
}

model UserLessonAccess {
  id        Int          @id @default(autoincrement())
  userId    Int
  lessonId  Int
  grantedAt DateTime     @default(now())
  lesson    Lesson       @relation(fields: [lessonId], references: [id])
  user      TrainingUser @relation(fields: [userId], references: [id])

  @@unique([userId, lessonId], name: "userId_lessonId")
}

model LessonAccessRequest {
  id        Int             @id @default(autoincrement())
  userId    Int
  lessonId  Int
  status    LessonReqStatus @default(PENDING)
  createdAt DateTime        @default(now())
  decidedAt DateTime?
  lesson    Lesson          @relation(fields: [lessonId], references: [id])
  user      TrainingUser    @relation(fields: [userId], references: [id])

  @@unique([userId, lessonId], name: "userId_lessonId_req")
}

model UserChapterProgress {
  id         Int       @id @default(autoincrement())
  userId     Int
  lessonId   Int
  chapterId  Int
  unlockedAt DateTime  @default(now())
  openedAt   DateTime? // когда реально нажал открыть (опционально)

  user    TrainingUser  @relation(fields: [userId], references: [id])
  lesson  Lesson        @relation(fields: [lessonId], references: [id])
  chapter LessonChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId], name: "userId_chapterId")
  @@index([userId, lessonId])
}

model LessonQuiz {
  id        Int      @id @default(autoincrement())
  lessonId  Int
  chapterId Int?
  title     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  lesson    Lesson         @relation(fields: [lessonId], references: [id])
  chapter   LessonChapter? @relation(fields: [chapterId], references: [id])
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id            Int    @id @default(autoincrement())
  quizId        Int
  text          String
  order         Int
  correctOption Int

  quiz       LessonQuiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options    QuizOption[]
  QuizAnswer QuizAnswer[]
}

model QuizOption {
  id         Int    @id @default(autoincrement())
  questionId Int
  text       String
  order      Int

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id         Int       @id @default(autoincrement())
  userId     Int
  quizId     Int
  score      Int       @default(0)
  total      Int
  finishedAt DateTime?
  createdAt  DateTime  @default(now())

  user    TrainingUser @relation(fields: [userId], references: [id])
  quiz    LessonQuiz   @relation(fields: [quizId], references: [id])
  answers QuizAnswer[]
}

model QuizAnswer {
  id             Int     @id @default(autoincrement())
  attemptId      Int
  questionId     Int
  selectedOption Int
  isCorrect      Boolean

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model LessonReview {
  id        Int      @id @default(autoincrement())
  lessonId  Int
  userId    Int
  rating    Int // 1-5
  comment   String?
  createdAt DateTime @default(now())

  user   TrainingUser @relation(fields: [userId], references: [id])
  lesson Lesson       @relation(fields: [lessonId], references: [id])

  @@unique([lessonId, userId])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LessonItemType {
  TEXT
  PHOTO
  VIDEO
  DOCUMENT
  LINK
  BUTTONS
}

enum LessonReqStatus {
  PENDING
  APPROVED
  REJECTED
}
